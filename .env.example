# Clé API OpenAI — utilisée uniquement en développement local (proxy Vite)
OPENAI_KEY=sk-...

# Personal Access Token GitHub (scope : contents:write) — pour publier la bibliothèque
GITHUB_TOKEN=ghp_...

# URL du Cloudflare Worker déployé — laissé vide en dev (proxy Vite prend le relai)
VITE_WORKER_URL=https://your-worker.your-subdomain.workers.dev
